spring.application.name=MyIkea
server.port=${PORT:8080}
spring.jpa.hibernate.ddl-auto=update
spring.jpa.database-platform=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.boot.allow_jdbc_metadata_access=false

# Database configuration - Use environment variables for security
# Variables requeridas:
#   - DB_HOST: Hostname del servidor MySQL (default: localhost)
#   - DB_PORT: Puerto del servidor MySQL (default: 3306)
#   - DB_NAME: Nombre de la base de datos (default: myikea)
#   - DB_USER: Usuario de MySQL (default: root)
#   - MYSQL: Contraseña de MySQL (REQUERIDO - debe estar definido como variable de entorno)

spring.datasource.url=jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:myikea}
spring.datasource.username=${DB_USER:root}
spring.datasource.password=${MYSQL}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
